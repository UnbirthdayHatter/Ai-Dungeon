rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, photoURL, createdAt, role
    //
    // Collection: roleplays
    // Fields: id, name, ownerId, systemRules, mood, updatedAt, joinCode, combat
    //
    // Sub-collection: messages
    // Fields: id, role, content, characterName, type, timestamp
    //
    // Sub-collection: lorebook
    // Fields: id, category, name, description, avatarUrl, imageUrl
    //
    // Sub-collection: sheets
    // Fields: id, type, name, avatarUrl, hp, maxHp, ac, stats, inventoryItems, ownerId, canEditAI
    //
    // Sub-collection: quests
    // Fields: id, title, description, status
    //
    // Sub-collection: timeline
    // Fields: id, date, event, description
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ( (request.auth.token.email == "UnbirthdayHatter@gmail.com") ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') );
    }

    function isRoleplayOwner(roleplayId) {
      return isAuthenticated() && get(/databases/$(database)/documents/roleplays/$(roleplayId)).data.ownerId == request.auth.uid;
    }

    function isRoleplayEditor(roleplayId) {
      let rpData = get(/databases/$(database)/documents/roleplays/$(roleplayId)).data;
      return isAuthenticated() && ('editors' in rpData) && (request.auth.uid in rpData.editors);
    }

    // Validation Functions
    function isValidUser(data) {
      return data.uid is string && data.email is string;
    }

    function isValidRoleplay(data) {
      return data.name is string && data.ownerId is string;
    }

    function isValidMessage(data) {
      return data.role in ['user', 'assistant', 'system', 'dice'] && data.content is string;
    }

    // User Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();

      match /sheets/{sheetId} {
        allow read, write: if isOwner(userId);
      }

      match /savedRoleplays/{roleplayId} {
        allow read, write: if isOwner(userId);
      }

      match /joinedRoleplays/{roleplayId} {
        allow read, write: if isOwner(userId);
      }

      match /config/{configId} {
        allow read, write: if isOwner(userId);
      }

      match /worldPresets/{presetId} {
        allow read, write: if isOwner(userId);
      }

      match /sheetTemplates/{templateId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Roleplay Rules
    match /roleplays/{roleplayId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoleplay(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isAuthenticated(); // Allow participants to update shared state like combat or isAIGenerating
      allow delete: if isRoleplayOwner(roleplayId) || isAdmin();

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidMessage(request.resource.data);
        allow update: if isAuthenticated(); // Allow editing messages if permitted by app logic
        allow delete: if isAdmin() || isRoleplayOwner(roleplayId);
      }

      match /lorebook/{loreId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (isRoleplayOwner(roleplayId) || isRoleplayEditor(roleplayId) || isAdmin());
      }

      match /sheets/{sheetId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated(); // Participants can update their sheets
      }

      match /quests/{questId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (isRoleplayOwner(roleplayId) || isRoleplayEditor(roleplayId) || isAdmin());
      }

      match /timeline/{timelineId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && (isRoleplayOwner(roleplayId) || isRoleplayEditor(roleplayId) || isAdmin());
      }

      match /typing/{userId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
